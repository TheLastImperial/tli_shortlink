<?xml version="1.0"?>
<odoo>
    <record id="tli_shortlink_model_action" model="ir.actions.act_window">
        <field name="name">ShortLinks</field>
        <field name="res_model">tli.shortlink</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="tli_shortlink_list_view" model="ir.ui.view">
        <field name="name">tli.shortlink.list.view</field>
        <field name="model">tli.shortlink</field>
        <field name="arch" type="xml">
           <list string="ShortLinks"
            edit="true"
           >
                <field string="Title" name="name"/>
                <field string="Description" name="description"/>
                <field string="URL" name="url"/>
                <field string="Short URL" name="sl"/>
            </list>
        </field>
    </record>

    <record id="tli_shortlink_create_view" model="ir.ui.view">
        <field name="name">tli.shortlink.create.view</field>
        <field name="model">tli.shortlink</field>
        <field name="arch" type="xml">
            <form string="New Shortlink">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="url" readonly="id != False"/>
                        <field name="sl" string="Shortlink" readonly="id != False"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
